# ════════════════════════════════════════════════════════════
#  MemoryVerse AI — Complete Environment Variables
#  cp .env.example .env   then fill in your keys
# ════════════════════════════════════════════════════════════

# ── 1. COHERE API (REQUIRED - FREE, no card needed) ───────────
# Get at: https://dashboard.cohere.com -> API Keys (trial key is automatic)
COHERE_API_KEY=

# ── 2. APP URL ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── 3. FIREBASE CLIENT (optional but recommended) ────────────
# Get at: https://console.firebase.google.com
# → Create project → Add Web App → Copy config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── 4. FIREBASE ADMIN (optional - enables Firestore + Storage) 
# Get at: console.firebase.google.com → Project Settings → Service accounts
# → Generate new private key → download JSON → copy values below
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── 5. GITHUB OAUTH (optional) ───────────────────────────────
# Get at: github.com/settings/developers → OAuth Apps → New
# Callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── 6. GOOGLE OAUTH FOR DRIVE (optional) ─────────────────────
# Get at: console.cloud.google.com → APIs & Services → Credentials
# Enable: Google Drive API. Callback: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 7. LINKEDIN OAUTH (optional) ─────────────────────────────
# Get at: linkedin.com/developers/apps → Create App
# Callback URL: http://localhost:3000/api/auth/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── 8. MICROSOFT / ONEDRIVE OAUTH (optional) ─────────────────
# Get at: portal.azure.com → App registrations → New registration
# Callback URL: http://localhost:3000/api/auth/microsoft/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
